  "info": {
    "_postman_id": "9bbe443d-c9e8-4e57-86a0-8ae328ce564c",
    "name": "Plasmic CMS API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Plasmic CMS is the headless content API for structured data managed\ninside Plasmic. Read and write rows in models defined in Studio. All\nrequests are authenticated with the\n`x-plasmic-api-cms-tokens: CMS_ID:TOKEN` header. Use the public token\nfor read operations and the secret token for write operations.\n\n\nContact Support:\n Name: API Evangelist\n Email: kin@apievangelist.com",
      "type": "text/plain"
    }
  }
